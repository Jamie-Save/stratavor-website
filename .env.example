# Optional: comma-separated hosts for `next dev` when opening via LAN IP
# (stops cross-origin warnings for /_next/*). Example:
# NEXT_ALLOWED_DEV_ORIGINS=10.0.0.131,192.168.1.50
# NEXT_ALLOWED_DEV_ORIGINS=

# Site assistant (OpenAI). Required for /api/chat. Set in Vercel/host secrets for production.
# OPENAI_API_KEY=
# Optional model id (default: gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Chatbot CTA: external sign-in destination.
# Keep APP_SIGNIN_URL as your source value and mirror it into NEXT_PUBLIC_APP_SIGNIN_URL
# for client-side rendering in the chatbot button.
# APP_SIGNIN_URL=
# NEXT_PUBLIC_APP_SIGNIN_URL=

# Chat API hardening (optional but recommended in production)
# Upstash Redis REST API for rate limiting POST /api/chat (create at https://upstash.com)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Max chat requests per IP per rolling minute (default 20)
# CHAT_RATE_LIMIT_PER_MINUTE=20
# Comma-separated allowed Origin values; empty = allow any. Use for production if you want to block drive-by API abuse.
# Example: https://stratavor.com,https://www.stratavor.com
# Preview deploys need their https://<project>-*.vercel.app origin listed if you enable this.
# CHAT_ALLOWED_ORIGINS=
