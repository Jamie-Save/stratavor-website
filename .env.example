# Optional: canonical origin for metadata, sitemap, robots, JSON-LD, llms.txt (default https://stratavor.com)
# Set on Vercel preview to match the deployment URL for correct OG URLs and canonicals.
# NEXT_PUBLIC_SITE_URL=https://stratavor.com

# Optional: comma-separated hosts for `next dev` when opening via LAN IP
# (stops cross-origin warnings for /_next/*). Example:
# NEXT_ALLOWED_DEV_ORIGINS=10.0.0.131,192.168.1.50
# NEXT_ALLOWED_DEV_ORIGINS=

# Optional: override HubSpot "Book a demo" scheduler URL (default: meetings-eu1.hubspot.com/… in contact-links.ts)
# NEXT_PUBLIC_BOOK_DEMO_CALENDAR_URL=

# Site assistant (OpenAI). Required for /api/chat. Set in Vercel/host secrets for production.
# OPENAI_API_KEY=
# Optional model id (default: gpt-5-mini)
# OPENAI_CHAT_MODEL=gpt-5-mini

# Chatbot CTA: external sign-in destination.
# Keep APP_SIGNIN_URL as your source value and mirror it into NEXT_PUBLIC_APP_SIGNIN_URL
# for client-side rendering in the chatbot button.
# APP_SIGNIN_URL=
# NEXT_PUBLIC_APP_SIGNIN_URL=

# Chat API hardening (optional but recommended in production)
# Upstash Redis REST API for rate limiting POST /api/chat (create at https://upstash.com)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Max chat requests per IP per rolling minute (default 20)
# CHAT_RATE_LIMIT_PER_MINUTE=20
# Comma-separated allowed Origin values; empty = allow any. Use for production if you want to block drive-by API abuse.
# Example: https://stratavor.com,https://www.stratavor.com
# Preview deploys need their https://<project>-*.vercel.app origin listed if you enable this.
# CHAT_ALLOWED_ORIGINS=

# ── Contact form → HubSpot (server-side submit, EU forms host) ──
# Required for POST /api/contact. Portal + form GUID from your HubSpot form embed.
# HUBSPOT_PORTAL_ID=49216937
# HUBSPOT_FORM_GUID=a767f224-ab0f-4ecd-9cb0-ac43455356c1
# EU default; use api.hsforms.com only if your portal is US-hosted.
# HUBSPOT_FORMS_HOST=api-eu1.hsforms.com
#
# Field internal names must exist on the HubSpot form (Settings → form fields → internal name).
# The site only requires email; other fields are optional and omitted from the API payload when empty.
# Defaults match typical HubSpot contact fields:
# HUBSPOT_FIELD_FIRSTNAME=firstname
# HUBSPOT_FIELD_LASTNAME=lastname
# HUBSPOT_FIELD_EMAIL=email
# HUBSPOT_FIELD_COMPANY=company
# HUBSPOT_FIELD_MESSAGE=message
# Dropdown internal name in HubSpot (default matches your form):
# HUBSPOT_FIELD_INTEREST=im_interested_in
# Option values sent must match HubSpot exactly: Personalized Demo | Pricing & Plans | Security Review | Partnership | Something Else
#
# Reuses Upstash Redis from chat (optional). If unset, contact rate limiting is skipped.
# CONTACT_RATE_LIMIT_PER_MINUTE=10
